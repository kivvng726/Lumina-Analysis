# 工作流引擎环境配置模板
# 复制此文件为 .env 并填写实际值

# =============================================================================
# 数据库配置 (必需)
# =============================================================================

# PostgreSQL 数据库连接URL
DATABASE_URL=postgresql://username:password@localhost:5432/workflow_engine

# 数据库连接池配置
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# AI模型配置 (可选，用于AI生成工作流功能)
# =============================================================================

# DeepSeek API配置
# 获取API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 模型配置
DEFAULT_MODEL=deepseek-chat
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4000

# =============================================================================
# 服务器配置
# =============================================================================

# API服务器配置
API_HOST=0.0.0.0
API_PORT=8123
DEBUG_MODE=false

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8123

# =============================================================================
# 监控和日志配置
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 监控配置
ENABLE_MONITORING=true
MONITORING_INTERVAL=60

# =============================================================================
# 工作流执行配置
# =============================================================================

# 执行配置
MAX_WORKFLOW_CONCURRENCY=10
DEFAULT_TIMEOUT=300
ENABLE_CACHING=true

# 节点执行配置
NODE_RETRY_COUNT=3
NODE_RETRY_DELAY=5

# =============================================================================
# 外部服务配置 (可选)
# =============================================================================

# Twitter API配置 (用于数据收集)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# Reddit API配置 (用于数据收集)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=workflow_engine/1.0

# 新闻API配置 (用于数据收集)
NEWS_API_KEY=your_news_api_key

# =============================================================================
# 存储配置
# =============================================================================

# 文件存储路径
STORAGE_PATH=./storage
UPLOAD_PATH=./storage/uploads

# 缓存配置
CACHE_TYPE=redis
CACHE_URL=redis://localhost:6379/0
CACHE_DEFAULT_TIMEOUT=300

# =============================================================================
# 安全配置
# =============================================================================

# JWT配置
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API密钥加密
ENCRYPTION_KEY=your_encryption_key_here

# =============================================================================
# 开发配置
# =============================================================================

# 开发模式
DEV_MODE=false

# 测试模式
TEST_MODE=false

# 调试工具
ENABLE_DEBUG_TOOLBAR=false
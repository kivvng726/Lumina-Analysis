# ========================================
# 工作流引擎环境配置示例
# ========================================
# 复制此文件为 .env 并根据实际情况修改配置

# ========================================
# DeepSeek API 配置
# ========================================
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL_NAME=deepseek-chat

# ========================================
# 数据库配置
# ========================================

# SQLite 配置（测试环境推荐）
# DATABASE_URL=sqlite:///workflow_test.db

# PostgreSQL 配置（生产环境推荐）
# 格式: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://workflow_user:your_secure_password@localhost:5432/workflow_db

# PostgreSQL 异步驱动（可选）
# 格式: postgresql+asyncpg://username:password@host:port/database_name
# DATABASE_URL=postgresql+asyncpg://workflow_user:your_secure_password@localhost:5432/workflow_db

# ========================================
# 数据库连接池配置（PostgreSQL）
# ========================================
# 连接池大小（默认 10）
DB_POOL_SIZE=10

# 连接池最大溢出连接数（默认 20）
DB_MAX_OVERFLOW=20

# 连接超时时间（秒，默认 30）
DB_POOL_TIMEOUT=30

# 连接回收时间（秒，默认 3600）
DB_POOL_RECYCLE=3600

# 连接前检查连接有效性（默认 True）
DB_POOL_PRE_PING=True

# ========================================
# Docker PostgreSQL 环境变量
# ========================================
# 如果使用 docker-compose.postgres.yml 部署，可配置以下变量
# POSTGRES_USER=workflow_user
# POSTGRES_PASSWORD=workflow_password
# POSTGRES_DB=workflow_db
# POSTGRES_PORT=5432

# pgAdmin 配置（可选）
# PGADMIN_EMAIL=admin@workflow.local
# PGADMIN_PASSWORD=admin123
# PGADMIN_PORT=5050

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
LOG_FILE=logs/workflow_engine.log

# ========================================
# API 服务器配置
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# ========================================
# 工作流引擎配置
# ========================================
DEFAULT_ENGINE=langgraph
WORKFLOW_TIMEOUT=300

# ========================================
# 性能优化配置（可选）
# ========================================
# 最大并发工作流数
MAX_CONCURRENT_WORKFLOWS=10

# 工作流执行超时（秒）
WORKFLOW_EXECUTION_TIMEOUT=600

# 节点执行超时（秒）
NODE_EXECUTION_TIMEOUT=60